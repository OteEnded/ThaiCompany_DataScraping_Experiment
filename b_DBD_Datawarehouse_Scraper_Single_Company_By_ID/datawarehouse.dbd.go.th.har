            "text": "import{Y as c}from\"./CptXCjuL.js\";const F=()=>{const e=c(),n=\"fin\";return{fetchBasicFinApi:(i,t,s)=>e.get(`/v1/${n}/basics/${i}/${t}`,{params:{fiscalYear:s}}),fetchFinSubmitHistApi:(i,t,s)=>e.get(`/v1/${n}/submit/${i}/${t}`,{params:{fiscalYear:s}}),fetchFinCompanyByYearApi:(i,t,s,p)=>e.get(`/v1/${n}/${p}/year/${i}/${t}`,{params:{fiscalYear:s}}),fetchFinCompanyByBizApi:(i,t,s,p)=>e.post(`/v1/${n}/${s}/biz/${i}/${t}`,p),fetchFinBizTypeByYearApi:(i,t,s)=>e.post(`/v1/${n}/business/${t}/year/${i}`,s),fetchFinBizTypeByBizApi:(i,t,s)=>e.post(`/v1/${n}/business/${t}/biz/${i}`,s),fetchCompareFinsApi:i=>e.post(`/v1/${n}/compare/finances`,i),fetchBasicFinChartsApi:(i,t)=>e.get(`/v1/${n}/basics/charts/${i}/${t}`)}};export{F as u};\n"
